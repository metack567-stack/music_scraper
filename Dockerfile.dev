# 开发环境Dockerfile
FROM python:3.11-slim

# 设置工作目录
WORKDIR /app

# 设置环境变量
ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    FLASK_APP=app.py \
    FLASK_ENV=development \
    FLASK_DEBUG=1

# 安装系统依赖
RUN apt-get update \
    && apt-get install -y \
        gcc \
        g++ \
        libmagic1 \
        libmagic-dev \
        build-essential \
        curl \
        vim \
    && rm -rf /var/lib/apt/lists/*

# 复制requirements文件
COPY requirements.txt .

# 安装Python依赖
RUN pip install --no-cache-dir -r requirements.txt

# 开发依赖
RUN pip install --no-cache-dir \
    debugpy \
    ipython \
    pytest \
    flake8

# 复制应用代码
COPY . .

# 创建必要的目录
RUN mkdir -p /app/uploads /app/database

# 设置权限
RUN chmod +x /app/app.py \
    && chown -R www-data:www-data /app

# 暴露端口
EXPOSE 5000 5001

# 启动命令
CMD ["python", "app.py"]