# .env配置文件模板
# 复制此文件为 .env 并根据需要修改配置

# Flask配置
FLASK_ENV=production
FLASK_APP=app.py

# 数据库配置
DATABASE_PATH=/app/database/music_metadata.db

# 上传配置
UPLOAD_FOLDER=/app/uploads
MAX_CONTENT_LENGTH=100000000  # 100MB文件大小限制

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=/app/logs/app.log

# 网络配置
HOST=0.0.0.0
PORT=5000

# 安全配置
SECRET_KEY=your-secret-key-here-change-this-in-production

# 扫描配置
SCAN_RECURSIVE=true
SCAN_MAX_DEPTH=10

# 处理配置
PROCESS_MAX_WORKERS=4
PROCESS_TIMEOUT=300  # 5分钟超时

# 整理配置
ORGANIZE_CLEANUP=true
ORGANIZE_DRY_RUN=false